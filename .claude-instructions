## Key Patterns & Templates

### Safe Message Passing
```javascript
// Background → Content
chrome.tabs.sendMessage(tabId, {
  action: 'executePrompt',
  messageId: `msg_${Date.now()}_${Math.random()}`,
  timestamp: Date.now(),
  payload: { prompt, variables }
}, (response) => {
  if (chrome.runtime.lastError) {
    console.error('Message failed:', chrome.runtime.lastError);
  }
});

// Content → Listen (with validation)
chrome.runtime.onMessage.addListener((msg, sender, respond) => {
  if (sender.id !== chrome.runtime.id) {
    console.error('Invalid sender');
    return;
  }
  
  if (!msg.messageId || !msg.action) {
    console.error('Invalid message');
    return;
  }
  
  try {
    // Process message...
  } catch (error) {
    console.error('Processing error:', error);
    respond({ error: error.message });
  }
});
```

### Platform Detection
```javascript
function detectPlatform(url) {
  const platforms = {
    'chatgpt.com': 'chatgpt',
    'claude.ai': 'claude',
    'gemini.google.com': 'gemini',
    'perplexity.ai': 'perplexity',
    'poe.com': 'poe',
    'grok.com': 'grok'
  };
  
  for (const [domain, name] of Object.entries(platforms)) {
    if (url.includes(domain)) return name;
  }
  return null;
}
```

### Variable Substitution (Safe)
```javascript
function replaceVariables(text, variables) {
  let result = text;
  
  // Sanitize variables
  const sanitized = {
    text: sanitizeInput(variables.text),
    url: sanitizeInput(variables.url),
    title: sanitizeInput(variables.title)
  };
  
  result = result.replace(/\{\{text\}\}/g, sanitized.text);
  result = result.replace(/\{\{url\}\}/g, sanitized.url);
  result = result.replace(/\{\{title\}\}/g, sanitized.title);
  
  return result;
}

function sanitizeInput(value) {
  const div = document.createElement('div');
  div.textContent = value; // Prevents HTML injection
  return div.innerHTML;
}
```

